{
  "name": "@tezosdynamics/contracts",
  "version": "0.0.1",
  "license": "MIT",
  "scripts": {
    "build": "heft build --clean",
    "build:watch": "heft build",
    "pre-compile": "node --loader ts-node/esm  src/lib/scripts/cli.ts compile -o src/lib/contracts/compiled -c",
    "pre-compile-m1": "node --loader ts-node/esm  src/lib/scripts/cli.ts compile -o src/lib/contracts/compiled -m true -c",
    "pre-compile-all": "rm -rf ./src/lib/contracts/compiled && node --loader ts-node/esm  src/lib/scripts/cli.ts compile -p src/lib/contracts/main -o src/lib/contracts/compiled",
    "pre-compile-all-m1": "rm -rf ./src/lib/contracts/compiled && node --loader ts-node/esm  src/lib/scripts/cli.ts compile -p src/lib/contracts/main -o src/lib/contracts/compiled -m true",
    "compile": "rushx pre-compile-all && rm -rf ./build && node --loader ts-node/esm  src/lib/scripts/cli.ts compile -f json -o src/lib/contracts/json ",
    "compile-m1": "rushx pre-compile-all-m1 && rm -rf ./build && node --loader ts-node/esm  src/lib/scripts/cli.ts compile -f json -o src/lib/contracts/json -m true ",
    "migrate": "rushx compile && node --loader ts-node/esm  src/lib/scripts/cli.ts migrate",
    "migrate-testnet": "rushx compile && node --loader ts-node/esm  src/lib/scripts/cli.ts migrate ghostnet",
    "migrate-testnet-kms": "rushx compile && node --loader ts-node/esm  src/lib/scripts/cli.ts migrate ithacanet-kms",
    "migrate-only": "node --loader ts-node/esm  src/lib/scripts/cli.ts migrate",
    "test-net-deploy": "NODE_ENV=development NETWORK_TO_MIGRATE_TO=hangzhounet ts-mocha --paths test/deploy/00_test_deployments.spec.ts --bail --timeout 900000",
    "test": "rushx migrate && ts-mocha --paths src/test/*.spec.ts --bail --timeout 900000",
    "test-full": "rushx compile && rushx migrate && ts-mocha --paths test/*.spec.ts --bail --timeout 500000",
    "test-full-m1": "rushx compile-m1 && rushx migrate && ts-mocha --paths test/*.spec.ts --bail --timeout 500000",
    "test-only": "ts-mocha --paths src/test/*.spec.ts --bail --timeout 300000",
    "test-single-file": "ts-mocha --bail --timeout 300000 --paths",
    "pytest": "rushx migrate && pytest -s",
    "pytest-only": "pytest -s",
    "clean": "rm -rf ./build && rm -rf src/lib/contracts/compiled && rm -rf ./deployments"
  },
  "type": "module",
  "main": "dist/libs/contracts/src/index.js",
  "typings": "dist/libs/contracts/src/index.d.ts",
  "dependencies": {
    "@chainsafe/libp2p-gossipsub": "^3.1.0",
    "@chainsafe/libp2p-noise": "^7.0.1",
    "@libp2p/bootstrap": "^2.0.0",
    "@libp2p/crypto": "~1.0.0",
    "@libp2p/floodsub": "^3.0.2",
    "@libp2p/interface-connection": "^2.1.1 ",
    "@libp2p/interface-peer-id": "^1.0.4",
    "@libp2p/interface-pubsub": "^1.0.4",
    "@libp2p/interface-transport": "^1.0.2",
    "@libp2p/interfaces": "^3.0.3",
    "@libp2p/kad-dht": "^3.0.0",
    "@libp2p/mplex": "^4.0.0",
    "@libp2p/peer-id-factory": "^1.0.15",
    "@libp2p/pubsub-peer-discovery": "^6.0.0",
    "@libp2p/tcp": "^3.0.1",
    "@libp2p/websockets": "^3.0.0",
    "@multiformats/multiaddr": "~10.1.8",
    "@nestjs/axios": "^0.0.7",
    "@nestjs/common": "^8.0.0",
    "@nestjs/core": "^8.0.0",
    "@nestjs/platform-express": "^8.0.0",
    "@nestjs/schedule": "^1.0.2",
    "@noble/ed25519": "~1.6.0",
    "@nodeutils/defaults-deep": "^1.1.0",
    "@taquito/michel-codec": "^13.0.1",
    "@taquito/michelson-encoder": "^13.0.1",
    "@taquito/remote-signer": "^13.0.1",
    "@taquito/rpc": "^13.0.1",
    "@taquito/signer": "^13.0.1",
    "@taquito/taquito": "^13.0.1",
    "@taquito/utils": "^13.0.1",
    "async-mutex": "^0.3.2",
    "axios": "~0.27.2",
    "bignumber.js": "^9.0.2",
    "convict": "^6.2.1",
    "heap": "~0.2.7",
    "it-first": "~1.0.7",
    "it-length-prefixed": "~7.0.1",
    "it-map": "~1.0.6",
    "it-pipe": "~2.0.3",
    "libp2p": "0.37.3-e6f646e",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.0.0",
    "seedrandom": "^3.0.5",
    "sha256": "^0.2.0",
    "tiny-typed-emitter": "~2.1.0",
    "ts-convict": "^1.1.0",
    "tslib": "^2.4.0",
    "uint8arrays": "~3.0.0",
    "yargs": "^17.5.1",
    "chai": "~4.3.6",
    "chai-as-promised": "~7.1.1"
  },
  "devDependencies": {
    "@nestjs/schematics": "^8.0.0",
    "@nestjs/testing": "^8.0.0",
    "@rushstack/heft": "^0.45.8",
    "@types/cron": "^1.7.3",
    "@types/jest": "27.0.2",
    "@types/node": "^16.11.7",
    "@types/yargs": "^17.0.10",
    "@typescript-eslint/eslint-plugin": "~5.10.0",
    "@typescript-eslint/parser": "~5.10.0",
    "eslint": "~8.7.0",
    "eslint-config-prettier": "8.1.0",
    "eslint-plugin-jest": "~26.2",
    "jest": "27.2.3",
    "prettier": "^2.5.1",
    "rimraf": "^3.0.2",
    "ts-jest": "27.0.5",
    "ts-node": "^10.7.0",
    "typescript": "~4.5.2",
    "webpack-merge": "^5.8.0",
    "webpack-node-externals": "^3.0.0",
    "@rushstack/eslint-config": "~2.6.1",
    "@types/heap": "~0.2.31",
    "@types/seedrandom": "~3.0.2"
  }
}
