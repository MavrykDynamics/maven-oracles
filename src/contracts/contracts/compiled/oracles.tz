                                           IF { PUSH nat 2 ;
                                                SWAP ;
                                                DIG 2 ;
                                                ADD ;
                                                EDIV ;
                                                IF_NONE { PUSH string "DIV by 0" ; FAILWITH } {} ;
                                                CAR }
                                              { DROP } } ;
                                      PUSH nat 1 ;
                                      DIG 2 ;
                                      ADD ;
                                      PAIR } ;
                               SWAP ;
                               DROP }
                             { SWAP ;
                               PAIR ;
                               DIG 2 ;
                               ITER { SWAP ;
                                      PAIR ;
                                      DUP ;
                                      CAR ;
                                      CAR ;
                                      PUSH nat 1 ;
                                      SWAP ;
                                      DUP ;
                                      DUG 2 ;
                                      ADD ;
                                      DUP 4 ;
                                      DIG 2 ;
                                      COMPARE ;
                                      EQ ;
                                      IF { SWAP ; CDR ; CAR } { SWAP ; CAR ; CDR } ;
                                      SWAP ;
                                      PAIR } ;
                               SWAP ;
                               DROP } ;
                          CDR ;
                          DUP 5 ;
                          CDR ;
                          CAR ;
                          CDR ;
                          SWAP ;
                          PAIR ;
                          PUSH nat 100 ;
