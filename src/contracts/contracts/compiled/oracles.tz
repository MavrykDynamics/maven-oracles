{ parameter
    (or (or (or (address %addWhiteListedContract)
                (contract %getLastCompletedRoundPrice
                   (pair (pair (int %decimals) (nat %percentOracleResponse))
                         (pair (int %price) (int %round)))))
            (or (address %removeWhiteListedContract) (unit %requestRateUpdate)))
        (or (or (pair %setObservation (int %price) (int %roundId)) (int %updateDecimals))
            (nat %updatePercentOracleTrust))) ;
  storage
    (pair (pair (pair (int %decimals)
                      (pair %lastCompletedRoundPrice
                         (pair (int %decimals) (nat %percentOracleResponse))
                         (pair (int %price) (int %round))))
                (pair (map %observations int (map address int)) (address %owner)))
          (pair (pair (nat %percentOracleTrust) (int %round))
                (map %whiteListedContract address bool))) ;
  code { NIL operation ;
         LAMBDA (pair address (map address bool)) bool { UNPAIR ; MEM } ;
         LAMBDA
           (pair (pair (pair int (pair (pair int nat) (pair int int)))
