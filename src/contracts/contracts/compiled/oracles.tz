                 (pair (pair nat int) (map address bool)))
           unit
           { CAR ;
             CDR ;
             CDR ;
             SENDER ;
             COMPARE ;
             NEQ ;
             IF { PUSH string "Only owner can do this action" ; FAILWITH } { UNIT } } ;
         LAMBDA
           (pair int (map int (map address int)))
           (map address int)
           { UNPAIR ; GET ; IF_NONE { PUSH string "No round here" ; FAILWITH } {} } ;
         DIG 4 ;
         UNPAIR ;
         IF_LEFT
           { DIG 2 ;
             DROP ;
             IF_LEFT
               { IF_LEFT
                   { SWAP ;
                     DUP ;
