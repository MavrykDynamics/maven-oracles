                     DUP ;
                     DUG 2 ;
                     COMPARE ;
                     GE ;
                     IF { DUP ;
                          EMPTY_MAP int int ;
                          DIG 5 ;
                          ITER { CDR ;
                                 SWAP ;
                                 DUP ;
                                 DUG 2 ;
                                 SWAP ;
                                 DUP ;
                                 DUG 2 ;
                                 GET ;
                                 IF_NONE { PUSH int 1 } { PUSH int 1 ; ADD } ;
